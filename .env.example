# ── Required: Vector store ─────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key

# ── Required: HuggingFace model access (gated model) ──────────────────────────
HF_TOKEN=hf_your_token_here

# ── Models (optional — defaults shown) ────────────────────────────────────────
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
GEN_MODEL=google/gemma-4-E4B-it

# ── Generation parameters (optional) ──────────────────────────────────────────
TEMPERATURE=0.7
MAX_NEW_TOKENS=512
TOP_P=0.9
TOKENIZER_MAX_LENGTH=2048
DO_SAMPLE=true
RETURN_TENSORS=pt
TRUNCATION=true

# ── Retrieval pipeline ─────────────────────────────────────────────────────────
ROUTING_ENABLED=true
COLBERT_ENABLED=false
HYDE_ENABLED=true
HYDE_MAX_TOKENS=150
HYDE_NUM_DRAFTS=1
HYDE_CONFIDENCE_THRESHOLD=0.5
QUERY_TIMEOUT_SECONDS=30
ASYNC_PIPELINE_ENABLED=true
TOP_K=5

# CRAG-style knowledge refinement (disabled by default)
REFINER_ENABLED=false                                       
REFINER_UPPER_THRESHOLD=0.0   # logit score above which a chunk is accepted
REFINER_LOWER_THRESHOLD=-3.0  # logit score below which a chunk is dropped
REFINER_STRIP_THRESHOLD=-1.0  # sentence-level score below which a strip is dropped

# ── Caching ────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000
REDIS_URL=redis://localhost:6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password

# ── API ────────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
HTTPS_ENABLED=true
TRUSTED_PROXY_COUNT=0
ALLOWED_ORIGINS=*
STATS_API_KEY=your_stats_api_key

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEVICE=cuda                               # cuda / mps / cpu

# ── Fine-tuned model (optional) ────────────────────────────────────────────────
LORA_ADAPTER_PATH=/path/to/lora/adapter

# ── Scripts only: SFT data generation ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Scripts only: Training on RunPod ─────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=pokesage-sft
WANDB_RUN_NAME=your_run_name
